[server]
# Port the built-in web server listens on
port = 7734

# Access token — shown in the tray menu; enter it once in the web UI
token = changeme

# Set to true when LZRD is running behind a reverse proxy such as Caddy.
# This lets Flask read the real client IP from the X-Forwarded-For header
# so that per-IP rate limiting works correctly for remote connections.
# Leave as false for direct local-network access.
behind_proxy = false

# Optional: the public URL you access LZRD through when behind a proxy
# (e.g. https://lzrd.yourdomain.com).  When set, this URL is shown in
# the system-tray tooltip instead of the local-network address.
# public_url =

[lzrd]
# Pixels the mouse must travel from its armed position before an alert fires
movement_threshold = 10

[auth]
# Owner credentials are created from the web UI on first launch.
# Leave these empty in this example file.
owner_username =
owner_password_hash =
